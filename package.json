{
  "name": "playwright-sdet-portfolio",
  "version": "1.0.0",
  "description": "This repository demonstrates a production-style QA automation framework using Playwright, TypeScript, UI testing, API testing, test fixtures, reusable page objects, CI execution, and test reporting. It is designed to reflect real-world SDET practices used in cross-functional product teams.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:e2e": "playwright test tests/e2e",
    "test:smoke": "playwright test --grep @smoke",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bimo-prabowo/playwright-sdet-portfolio.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/bimo-prabowo/playwright-sdet-portfolio/issues"
  },
  "homepage": "https://github.com/bimo-prabowo/playwright-sdet-portfolio#readme",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
